# CLion
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#cmake-build-*

# Python (PC-side visualizer / tooling)
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Build artifacts
build/
# native transform DLL build tree (already matched by build/ above; kept explicit per task brief)
host/transform/build/
dist/
*.elf
*.bin
*.map
*.o
*.d

# Captured data (keep the repo light). recordings/ is NOT ignored: it holds
# small shareable scans for playback (see !recordings/*.bin below).
*.raw
*.bag
captures/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local env
.env
.env.local

# git worktrees (superpowers:using-git-worktrees)
.worktrees/

# golden test fixtures are deliberately tracked despite *.bin above
!host/tests/fixtures/*.bin

# shareable scan recordings are deliberately tracked despite *.bin above
!recordings/*.bin

# KiCad auto-generated / local artifacts (references/kicad stack model)
*.lck
~*.lck
*-erc.rpt
*-backups/
_autosave-*
fp-info-cache

# KiCad project-local (per-user) settings
*.kicad_prl

# Bulky board fab data — re-downloadable from ST, kept local, not in git (see wrap-up decision B)
references/datasheets/NUCLEO-H563ZI/schematic/mb1404-manufacturing/
references/datasheets/NUCLEO-IKS4A1/schematic/x-nucleo-iks4a1-gerber/
references/datasheets/NUCLEO-VL53L9CX/schematic/x-nucleo-53l9a1-gerber/
# Duplicated datasheet PDFs under the KiCad model (originals live in references/datasheets/)
references/kicad/roomscanner-stack/datasheets/
